0e3d			;	DEFB	B2HEX 
0e3d			;	RST SCAL 
0e3d			;	DEFB SPACE       ; and space 
0e3d			 
0e3d 3a 88 0c			LD	A,(TESTVALUE)	; check if it is the same as LD A command  
0e40 bb				CP	E 
0e41 3e 44			LD	A,"D"	 ; set error code to D 
0e43 c4 c5 0e			CALL NZ,ERR      ; Fault D if the LD A,TESTVALUE failed 

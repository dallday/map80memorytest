0f5d 66				DEFB TBCD3 
0f5e			 
0f5e ef				RST PRS 
0f5f ..				DEFM "E:" 
0f61 00				DEFB 0 
0f62 2a 95 0c			LD HL,(ENDADDR)     ; finish address 
0f65 2b				DEC HL 
0f66 df				RST SCAL         ; print address 
0f67 66				DEFB TBCD3 
0f68 c9			    RET  
0f69			 
0f69			     
0f69			;-------------------- V3 - output the type of test  
0f69			DISPSIZE: 
0f69			    ; Sets C to the page type (PAGETYPE)  
0f69			    ; Sets B to the number of pages to do ( NO64KPAGES )  
0f69			    ;  will be *2 if doing 32k pages (PAGETYPE != 0 ) 
0f69			    ;  A == B and the Z flag is set if PAGETYPE == 0 ( 64k paging ) 
0f69 cd 1d 0e		    CALL GETPAGETYPE 
0f6c			     
0f6c			    ; LD  A,B     ; retrieve no64kpages - already in A 
0f6c			 
0f6c b7				OR  A 
0f6d 28 1a			JR  Z,DISPEND		; if zero then no paging 
0f6f 79				LD A,C          ; load page type 
0f70			;	OR A		; check for Zero by using OR 
0f70 e6 c0		    AND 0C0H    ; if top 2 bits 0 then doing 64k pages 
0f72 28 10			JR Z,REP64K ; if (PAGETYPE) is zero then doing 64k pages 
0f74						; doing 32k pages 
0f74 ef				RST PRS 
0f75 ..				DEFM "32K" 
0f78 00				DEFB 0 
0f79 79				LD A,C          ; load page type again 
0f7a e6 40		    AND 40H         ; see if the bit 6 set then upper 32k locked ?? TODO 
0f7c			;	LD A,"U" 
0f7c			;	JR NZ,DISPUL    ; if NZ then the bit was set meaning testing in the upper 32k page 
0f7c			;	LD A,"L" 
0f7c 3e 4c			LD A,"L" 
0f7e 20 02			JR NZ,DISPUL    ; if NZ then the bit was set meaning testing in the upper 32k page 
0f80 3e 55			LD A,"U" 
0f82			DISPUL: 
0f82 f7				RST ROUT	; output the single character 
0f83 c9				RET         ; return as now finished 
0f84			REP64K: 
0f84 ef				RST PRS 
0f85 ..				DEFM "64K" 
0f88 00				DEFB 0 
0f89			DISPEND: 
0f89 c9				RET 
0f8a			 
0f8a			DISPTITLE: 
0f8a ef				RST PRS		; clear current line 
0f8b 1b 00			DEFB ESC,0 
0f8d ef				RST PRS 
0f8e ..				DEFM "M80MEMTP V5 " 
0f9a 00				DEFB 0 
0f9b c9			    RET 
0f9c			 
0f9c			; V3 moved stack to end of code 
0f9c			;  our own stack to use - also used for opcode call 
0f9c			; used values so I could check and see how much we used  
0f9c			; after run seemed to only get down to 27 leaving 28 (8 bytes ) free 
0f9c			;  so commented out the other spaces 
0f9c			STACKSPACE: 
0f9c			;		DEFB 	3FH, 3EH, 3DH, 3CH, 3BH, 3AH, 39H, 38H 
0f9c			;		DEFB 	37H, 36H, 35H, 34H, 33H, 32H, 31H, 30H 
0f9c			 
0f9c 2f 2e 2d 2c 2b 2a 29 28			DEFB 	2FH, 2EH, 2DH, 2CH, 2BH, 2AH, 29H, 28H 
0fa4 27 26 25 24 23 22 21 20			DEFB 	27H, 26H, 25H, 24H, 23H, 22H, 21H, 20H 
0fac 1f 1e 1d 1c 1b 1a 19 18			DEFB 	1FH, 1EH, 1DH, 1CH, 1BH, 1AH, 19H, 18H 
0fb4 17 16 15 14 13 12 11 10			DEFB 	17H, 16H, 15H, 14H, 13H, 12H, 11H, 10H 
0fbc 0f 0e 0d 0c 0b 0a 09 08			DEFB 	0FH, 0EH, 0DH, 0CH, 0BH, 0AH, 09H, 08H 
0fc4 07 06 05 04 03 02 01 00			DEFB 	07H, 06H, 05H, 04H, 03H, 02H, 01H, 00H 
0fcc			 
0fcc			TSTSTACK:	EQU $		; the program stack starts here 

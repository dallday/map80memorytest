0eaa d5				PUSH DE          ; No need to save A register 
0eab e5				PUSH HL 
0eac ed 5b 29 0c		LD DE,(CURSOR)   ; get current cursor on screen 
0eb0 21 f5 0b			LD HL,0BF5H	; set screen to heading line 
0eb3				             ; V2 moved placment of the address value left by 1 
0eb3 22 29 0c			LD (CURSOR),HL	 
0eb6 e1				POP HL 
0eb7 e5				PUSH HL 
0eb8 df				RST SCAL         ; print current address 
0eb9 66				DEFB TBCD3 

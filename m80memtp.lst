0ed1 6a				DEFB CRLF 
0ed2 3a 90 0c			LD A,(ERRORS) 
0ed5 3c				INC A 
0ed6 fe 0a			CP 0AH 
0ed8 20 04			JR NZ,ERRJUSTCR 
0eda cd eb 0e			CALL WAIT 
0edd af				XOR A	; reset error count  

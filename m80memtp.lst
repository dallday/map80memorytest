0e7d cd 85 0e			CALL OUTPAGE1	; output details 
0e80 e3				EX (SP),HL	; get cursor and save HL 
0e81 22 29 0c			LD (CURSOR),HL 
0e84 e1				POP HL		; get address 
0e85			 
0e85			OUTPAGE1:	; call here to output page where the cursor is 
0e85 3a 85 0c			LD A,(NO64KPAGES) 
0e88 b7				OR A 
0e89 c8				RET Z	; return if doing non paging processing 
0e8a ef				RST PRS 
0e8b ..				DEFM "pg:"      ; V2 shorten the page text to accommodate moving the address value 
0e8e 00				DEFB 0 
0e8f 7d				LD A,L		; bring down just the lower parts of L 
0e90						; which is the Port value to set page 
0e90 3d				DEC A		; actually the next page so reduce by 1 
0e91						; ( Port value incremented after setting port ) 
0e91 e6 3f		    	AND 3FH		; remove the 2 control bits 
0e93 cb 3f			SRL A		; shift to right by 1 and sets carry flag 
0e95 f5				PUSH	AF	; save the carry flag 
0e96 df				RST SCAL    ; print  port value 
0e97 68				DEFB B2HEX 
0e98				;RST SCAL         ; output space 
0e98				;DEFB SPACE 
0e98 3a 87 0c			LD  A,(PAGETYPE) 	; check type of test 
0e9b b7				OR A		; or wih self will set z flag if zeros 
0e9c 28 09			JR Z,PAGE64	; 64k tests 
0e9e f1				POP AF		; Get Carry flag 
0e9f 3e 55			LD A,"U" 
0ea1 38 02			JR C,UPPER	; if carry set then upper 32k page 
0ea3 3e 4c			LD A,"L" 
0ea5			UPPER: 
0ea5 f7			    	RST ROUT	; output the single character 
0ea6 c9				RET 
0ea7			PAGE64:			; no further action 
0ea7 f1				POP AF 
0ea8 c9				RET 

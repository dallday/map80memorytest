0d93			; -------------------    walking bit test 
0d93 3e 01			LD A,1           ; intial bit position  
0d95 77			WALK:	LD (HL),A        ; put into memory 
0d96 be				CP (HL)          ; did it get there 
0d97 f5				PUSH AF          ; save bit pattern 
0d98 3e 42			LD A,"B"         ; load error code in case 
0d9a c4 c5 0e			CALL NZ,ERR      ; report Fault B if walk failed 
0d9d f1				POP AF           ; get bit pattern and flags from stack 
0d9e 20 03			JR NZ,LOADFF     ; if it failed jump to next test 
0da0 17				RLA              ; move bit to next position 
0da1 30 f2			JR NC,WALK       ; repeat until the bit reaches the carry flag 
0da3			 
0da3			;-------------------- Load FF test   

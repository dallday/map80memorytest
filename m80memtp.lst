0ecb 66				DEFB TBCD3 
0ecc 14				INC D            ; tell calling code Err called 
0ecd c1				POP BC           ; retrieve count 
0ece f1				POP AF           ; retrieve flags 
0ecf c9				RET              ; return 
0ed0			 
0ed0			; ------------------ routine to output a newline on screen 
0ed0			;                    if an error has occurred 

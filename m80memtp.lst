0def			;------------------------- get page type 
0def			; V3 added this routine as used more than once 
0def			GETPAGETYPE: 
0def			    ; Sets C to the page type (PAGETYPE)  
0def			    ; Sets B to the number of pages to do ( NO64KPAGES )  
0def			    ;  will be *2 if doing 32k pages (PAGETYPE != 0 ) 
0def			    ; A == B and the Z flag is set if PAGETYPE == 0 ( 64k paging ) 
0def			     
0def 3a 87 0c		    LD  A,(PAGETYPE)	; load the value to set the first page 
0df2 4f				LD  C,A       	; value that starts with page 0 
0df3 b7				OR  A		; if zero then doing 64k pages 
0df4 3a 85 0c			LD  A, (NO64KPAGES)	; get number of pages to check 
0df7				; next test checking previous or 
0df7 28 01			JR  Z,GETPAGETYPE64K		; flag set by previous OR A  
0df9						; doing 32k pages so need to double the number of tests done 
0df9 17				RLA			; shift left == multiply by 2 ( carry bit reset by OR A ) 
0dfa							; needed so we can do 2 32k tests on each 64k page	 
0dfa			GETPAGETYPE64K: 
0dfa 47				LD  B,A			; store away for later count down 
0dfb c9			    RET 
0dfc			 
0dfc			 
0dfc			;---------------------- do opcode test 
0dfc			;                       as a subroutine as main loop was too big for JR commands 
0dfc			OPCODETEST: 
0dfc			 
0dfc			LOADOPCODE: 
0dfc e5				PUSH HL 
0dfd 21 00 0e			LD HL,DUMMY 
0e00			DUMMY: 
0e00 7e				LD A,(HL)	 ; dummy to get code value	 
0e01 e1				POP HL 
0e02 77				LD (HL),A	; LD A,(HL) 
0e03			 
0e03 e5				PUSH HL		; save current registers 
0e04 d5			 	PUSH DE 
0e05 c5				PUSH BC 
0e06				; save current stack so we can reset it later 
0e06 ed 73 8c 0c		LD (SAVESTACK),SP 
0e0a			  
0e0a				; set stack pointer for the test 
0e0a				; LD      SP,TSTSTACK 
0e0a				; assuming we don't need to and can use our own stack 
0e0a				; put user pc on top of stack 
0e0a e5				PUSH	HL	; add HL to top of stack  
0e0b			 
0e0b				; do step commands 
0e0b				; set so the NMI address is our routine 
0e0b				;  NMI address starts with a JP  
0e0b 2a 7e 0c			LD HL,(NMI+1) 
0e0e 22 8e 0c			LD (SAVENMI),HL 
0e11 21 24 0e			LD HL,TRAP 
0e14 22 7e 0c			LD (NMI+1),HL 
0e17 21 88 0c			LD HL,TESTVALUE	; point HL at the test value 
0e1a 3e aa			LD A,0AAH	; set A and then see if it changes value 
0e1c			 
0e1c				; set bit 3 of p0, to activate nmi 
0e1c f5				PUSH AF 
0e1d 3e 08			LD   A,8 
0e1f d3 00			OUT  (0),A 
0e21 f1				POP  AF 
0e22			        ; execute one step of program 
0e22 ed 45			RETN	; not sure why RETN? 
0e24			 
0e24			; come here after nmi or bpt 
0e24			TRAP: 
0e24				; reset NMI address 
0e24 2a 8e 0c			LD HL,(SAVENMI) 
0e27 22 7e 0c			LD (NMI+1),HL 
0e2a 32 92 0c			LD	(SAVERESULT),A	; save result 
0e2d				; reset nmi bit in p0 
0e2d 3a 00 0c			LD   A,(PORT0) 
0e30 d3 00			OUT  (0),A 
0e32			 
0e32				; set my stack pointer 
0e32 ed 7b 8c 0c		LD      SP,(SAVESTACK) 
0e36			 
0e36 c1				POP	BC	; restore registers 

0e70			;------------- output page number  
0e70			; in header area and on current line 
0e70			OUTPAGE: ; call here to output page details in the header 
0e70				; at the heading line 
0e70 e5				PUSH HL		; save address to stack 
0e71 2a 29 0c			LD HL,(CURSOR) 
0e74 e3				EX (SP),HL	; exchange cursor value with address in stack 
0e75 e5				PUSH HL		; re save address to stack 
0e76 21 ed 0b			LD HL,0BEDH	; set screen to heading line 
0e79 22 29 0c			LD (CURSOR),HL	 
